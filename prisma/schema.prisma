generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public"]
}

model Profile {
  id                 String              @id
  email              String              @unique
  fullName           String?
  avatarUrl          String?
  phone              String?
  nicNumber          String?             @unique
  dateOfBirth        DateTime?
  gender             Gender?
  nationality        String?             @default("Sri Lankan")
  address            String?
  city               String?
  district           String?
  role               Role                @default(STUDENT)
  isVerified         Boolean             @default(false)
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  is_admin           Boolean             @default(false)
  announcements      Announcement[]
  employer           Employer?
  lecturer           Lecturer?
  notifications      Notification[]
  payments           Payment[]
  student            Student?
  subscriptions      Subscription[]
  institutionAccount InstitutionAccount?

  @@schema("public")
}

model Institution {
  id                  String                    @id @default(cuid())
  name                String
  slug                String                    @unique
  type                InstitutionType
  description         String?
  logoUrl             String?
  website             String?
  email               String?
  phone               String?
  address             String?
  city                String?
  country             String                    @default("Sri Lanka")
  accreditationBody   String?
  accreditationNumber String?
  isVerified          Boolean                   @default(false)
  isActive            Boolean                   @default(true)
  approvalStatus      InstitutionApprovalStatus @default(PENDING)
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  announcements       Announcement[]
  lecturers           Lecturer[]
  managers            InstitutionManager[]
  programs            Program[]
  account             InstitutionAccount?

  @@schema("public")
}

model InstitutionManager {
  id                   String      @id @default(cuid())
  institutionId        String
  lecturerId           String
  canEditProfile       Boolean     @default(false)
  canManagePrograms    Boolean     @default(true)
  canViewAnalytics     Boolean     @default(true)
  canPostAnnouncements Boolean     @default(false)
  assignedAt           DateTime    @default(now())
  assignedBy           String?
  institution          Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  lecturer             Lecturer    @relation(fields: [lecturerId], references: [id], onDelete: Cascade)

  @@unique([institutionId, lecturerId])
  @@schema("public")
}

model InstitutionAccount {
  id            String      @id @default(cuid())
  profileId     String      @unique
  institutionId String      @unique
  createdAt     DateTime    @default(now())
  profile       Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@schema("public")
}

model Program {
  id                   String                @id @default(cuid())
  institutionId        String
  createdById          String?
  reviewedById         String?
  title                String
  slug                 String                @unique
  type                 ProgramType
  level                ProgramLevel
  field                ProgramField
  durationMonths       Int?
  deliveryMode         DeliveryMode
  language             String[]
  description          String?
  entryRequirements    String?
  careerOutcomes       String?
  creditPoints         Int?
  creditFramework      String?
  localPrice           Decimal?              @db.Decimal(10, 2)
  foreignPrice         Decimal?              @db.Decimal(10, 2)
  scholarshipAvailable Boolean               @default(false)
  isPublished          Boolean               @default(false)
  isActive             Boolean               @default(true)
  approvalStatus       ProgramApprovalStatus @default(DRAFT)
  reviewNote           String?
  reviewedAt           DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  announcements        Announcement[]
  courses              Course[]
  credentials          Credential[]
  enrollments          Enrollment[]
  institution          Institution           @relation(fields: [institutionId], references: [id])
  createdBy            Lecturer?             @relation("ProgramCreator", fields: [createdById], references: [id])
  reviewedBy           Lecturer?             @relation("ProgramReviewer", fields: [reviewedById], references: [id])

  @@schema("public")
}

model Course {
  id                String             @id @default(cuid())
  programId         String?            // nullable — standalone courses have no program
  createdById       String?            // lecturer who owns this course
  title             String
  code              String?
  description       String?
  creditHours       Int?
  semester          Int?
  year              Int?
  isMandatory       Boolean            @default(true)
  orderIndex        Int                @default(0)
  isStandalone      Boolean            @default(false)   // true = independent course
  isPublished       Boolean            @default(false)
  localPrice        Decimal?           @db.Decimal(10, 2)
  foreignPrice      Decimal?           @db.Decimal(10, 2)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  assessments       Assessment[]
  program           Program?           @relation(fields: [programId], references: [id])
  createdBy         Lecturer?          @relation("CourseCreator", fields: [createdById], references: [id])
  courseEnrollments CourseEnrollment[]
  courseLecturers   CourseLecturer[]
  resources         CourseResource[]
  sections          CourseSection[]

  @@schema("public")
}

model CourseSection {
  id           String           @id @default(cuid())
  courseId     String
  title        String
  description  String?
  instructions String?          // Markdown — shown to students
  orderIndex   Int              @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  course       Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  resources    CourseResource[]

  @@schema("public")
}

model CourseResource {
  id          String             @id @default(cuid())
  courseId    String
  sectionId   String?            // null = unsectioned (legacy)
  title       String
  type        CourseResourceType
  fileUrl     String?
  externalUrl String?
  description String?
  orderIndex  Int                @default(0)
  isPublished Boolean            @default(true)
  sizeBytes    Int?
  mimeType     String?
  durationMins Int?               // estimated read/watch time in minutes
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  course       Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  section      CourseSection?     @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  progress     ResourceProgress[]

  @@schema("public")
}

model Lecturer {
  id                  String                 @id @default(cuid())
  profileId           String                 @unique
  institutionId       String?
  title               String?
  specialization      String[]
  qualifications      String?
  experienceYears     Int?
  bio                 String?
  linkedinUrl         String?
  isVisiting          Boolean                @default(false)
  hourlyRate          Decimal?               @db.Decimal(10, 2)
  isAvailable         Boolean                @default(true)
  rating              Decimal                @default(0) @db.Decimal(3, 2)
  totalReviews        Int                    @default(0)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  approvalStatus      LecturerApprovalStatus @default(PENDING)
  courseLecturers     CourseLecturer[]
  managedInstitutions InstitutionManager[]
  institution         Institution?           @relation(fields: [institutionId], references: [id])
  profile             Profile                @relation(fields: [profileId], references: [id])
  createdPrograms     Program[]              @relation("ProgramCreator")
  reviewedPrograms    Program[]              @relation("ProgramReviewer")
  createdCourses      Course[]               @relation("CourseCreator")

  @@schema("public")
}

model CourseLecturer {
  id         String       @id @default(cuid())
  courseId   String
  lecturerId String
  role       LecturerRole @default(LECTURER)
  assignedAt DateTime     @default(now())
  course     Course       @relation(fields: [courseId], references: [id])
  lecturer   Lecturer     @relation(fields: [lecturerId], references: [id])

  @@schema("public")
}

model Student {
  id                String                 @id @default(cuid())
  profileId         String                 @unique
  studentNumber     String?                @unique
  olResults         Json?
  alResults         Json?
  previousEducation String?
  employmentStatus  EmploymentStatus?
  targetCareer      String?
  emergencyContact  Json?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  submissions       AssessmentSubmission[]
  credentials       Credential[]
  enrollments       Enrollment[]
  jobApplications   JobApplication[]
  courseEnrollments CourseEnrollment[]
  resourceProgress  ResourceProgress[]
  profile           Profile                @relation(fields: [profileId], references: [id])

  @@schema("public")
}

model Enrollment {
  id                 String             @id @default(cuid())
  studentId          String
  programId          String
  status             EnrollmentStatus   @default(PENDING)
  enrollmentDate     DateTime?
  expectedCompletion DateTime?
  actualCompletion   DateTime?
  currentYear        Int                @default(1)
  currentSemester    Int                @default(1)
  scholarshipType    String?
  scholarshipAmount  Decimal?           @db.Decimal(10, 2)
  notes              String?
  approvedBy         String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  courseEnrollments  CourseEnrollment[]
  credentials        Credential[]
  program            Program            @relation(fields: [programId], references: [id])
  student            Student            @relation(fields: [studentId], references: [id])
  payments           Payment[]

  @@schema("public")
}

model CourseEnrollment {
  id           String                 @id @default(cuid())
  enrollmentId String
  studentId    String?
  courseId     String
  status       CourseEnrollmentStatus @default(ACTIVE)
  grade        String?
  gradePoints  Decimal?               @db.Decimal(3, 2)
  completedAt  DateTime?
  createdAt    DateTime               @default(now())
  course       Course                 @relation(fields: [courseId], references: [id])
  enrollment   Enrollment             @relation(fields: [enrollmentId], references: [id])
  student      Student?               @relation(fields: [studentId], references: [id])

  @@schema("public")
}

model Assessment {
  id            String                 @id @default(cuid())
  courseId      String
  title         String
  type          AssessmentType
  totalMarks    Int?
  passMarks     Int?
  weightPercent Decimal?               @db.Decimal(5, 2)
  dueDate       DateTime?
  instructions  String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  course        Course                 @relation(fields: [courseId], references: [id])
  submissions   AssessmentSubmission[]

  @@schema("public")
}

model AssessmentSubmission {
  id             String           @id @default(cuid())
  assessmentId   String
  studentId      String
  fileUrl        String?
  submissionText String?
  submittedAt    DateTime         @default(now())
  marksObtained  Decimal?         @db.Decimal(6, 2)
  feedback       String?
  gradedBy       String?
  gradedAt       DateTime?
  status         SubmissionStatus @default(SUBMITTED)
  assessment     Assessment       @relation(fields: [assessmentId], references: [id])
  student        Student          @relation(fields: [studentId], references: [id])

  @@schema("public")
}

model ResourceProgress {
  id          String        @id @default(cuid())
  studentId   String
  resourceId  String
  completedAt DateTime      @default(now())
  student     Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  resource    CourseResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([studentId, resourceId])
  @@schema("public")
}

model LibraryResource {
  id            String       @id @default(cuid())
  title         String
  type          ResourceType
  subject       String?
  field         String?
  author        String?
  publisher     String?
  yearPublished Int?
  description   String?
  fileUrl       String?
  thumbnailUrl  String?
  isFree        Boolean      @default(false)
  accessLevel   AccessLevel  @default(ENROLLED)
  downloads     Int          @default(0)
  views         Int          @default(0)
  uploadedBy    String?
  createdAt     DateTime     @default(now())

  @@schema("public")
}

model Credential {
  id               String         @id @default(cuid())
  studentId        String
  enrollmentId     String?
  programId        String?
  credentialType   CredentialType
  title            String
  issuedBy         String?
  issueDate        DateTime?
  certificateUrl   String?
  verificationCode String         @unique @default(cuid())
  isValid          Boolean        @default(true)
  createdAt        DateTime       @default(now())
  enrollment       Enrollment?    @relation(fields: [enrollmentId], references: [id])
  program          Program?       @relation(fields: [programId], references: [id])
  student          Student        @relation(fields: [studentId], references: [id])

  @@schema("public")
}

model Employer {
  id             String                 @id @default(cuid())
  profileId      String                 @unique
  companyName    String
  industry       String?
  companySize    String?
  website        String?
  logoUrl        String?
  description    String?
  isVerified     Boolean                @default(false)
  createdAt      DateTime               @default(now())
  approvalStatus EmployerApprovalStatus @default(PENDING)
  profile        Profile                @relation(fields: [profileId], references: [id])
  jobListings    JobListing[]

  @@schema("public")
}

model JobListing {
  id                     String           @id @default(cuid())
  employerId             String
  title                  String
  type                   JobType
  location               String?
  isRemote               Boolean          @default(false)
  salaryMin              Decimal?         @db.Decimal(12, 2)
  salaryMax              Decimal?         @db.Decimal(12, 2)
  currency               String           @default("LKR")
  description            String?
  requirements           String?
  requiredQualifications String[]
  preferredFields        String[]
  applicationDeadline    DateTime?
  isActive               Boolean          @default(true)
  views                  Int              @default(0)
  createdAt              DateTime         @default(now())
  expiresAt              DateTime?
  jobApplications        JobApplication[]
  employer               Employer         @relation(fields: [employerId], references: [id])

  @@schema("public")
}

model JobApplication {
  id          String            @id @default(cuid())
  jobId       String
  studentId   String
  coverLetter String?
  cvUrl       String?
  status      ApplicationStatus @default(APPLIED)
  appliedAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  job         JobListing        @relation(fields: [jobId], references: [id])
  student     Student           @relation(fields: [studentId], references: [id])

  @@schema("public")
}

model Payment {
  id              String        @id @default(cuid())
  profileId       String
  enrollmentId    String?
  amount          Decimal       @db.Decimal(12, 2)
  currency        String        @default("LKR")
  paymentType     PaymentType
  paymentMethod   PaymentMethod
  stripePaymentId String?
  stripeSessionId String?
  status          PaymentStatus @default(PENDING)
  paidAt          DateTime?
  notes           String?
  createdAt       DateTime      @default(now())
  enrollment      Enrollment?   @relation(fields: [enrollmentId], references: [id])
  profile         Profile       @relation(fields: [profileId], references: [id])

  @@schema("public")
}

model Subscription {
  id                   String             @id @default(cuid())
  profileId            String
  plan                 SubscriptionPlan
  status               SubscriptionStatus @default(ACTIVE)
  startsAt             DateTime           @default(now())
  expiresAt            DateTime?
  stripeSubscriptionId String?
  amount               Decimal?           @db.Decimal(10, 2)
  currency             String             @default("LKR")
  createdAt            DateTime           @default(now())
  profile              Profile            @relation(fields: [profileId], references: [id])

  @@schema("public")
}

model Notification {
  id        String           @id @default(cuid())
  profileId String
  title     String
  message   String?
  type      NotificationType
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())
  profile   Profile          @relation(fields: [profileId], references: [id])

  @@schema("public")
}

model Announcement {
  id             String       @id @default(cuid())
  title          String
  content        String?
  targetAudience String[]     @default(["all"])
  institutionId  String?
  programId      String?
  isPublished    Boolean      @default(false)
  publishedBy    String?
  publishedAt    DateTime?
  expiresAt      DateTime?
  createdAt      DateTime     @default(now())
  institution    Institution? @relation(fields: [institutionId], references: [id])
  program        Program?     @relation(fields: [programId], references: [id])
  publisher      Profile?     @relation(fields: [publishedBy], references: [id])

  @@schema("public")
}

// ── Enums ──────────────────────────────────────────────────────────────────

enum Role {
  STUDENT
  LECTURER
  EMPLOYER
  INSTITUTION
  ADMIN

  @@schema("public")
}

enum Gender {
  MALE
  FEMALE
  OTHER

  @@schema("public")
}

enum InstitutionType {
  PUBLIC_UNIVERSITY
  PRIVATE_UNIVERSITY
  FOREIGN_UNIVERSITY
  TRAINING_INSTITUTE
  PROFESSIONAL_BODY
  CORPORATE_ACADEMY

  @@schema("public")
}

enum InstitutionApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED

  @@schema("public")
}

enum LecturerApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED

  @@schema("public")
}

enum EmployerApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED

  @@schema("public")
}

enum ProgramApprovalStatus {
  DRAFT
  PENDING
  APPROVED
  CHANGES_REQUESTED

  @@schema("public")
}

enum ProgramType {
  FOUNDATION
  DIPLOMA
  CERTIFICATE
  BACHELOR
  MASTER
  PHD
  PROFESSIONAL
  MICROCREDENTIAL
  SHORT_COURSE

  @@schema("public")
}

enum ProgramLevel {
  ENTRY
  UNDERGRADUATE
  POSTGRADUATE
  RESEARCH

  @@schema("public")
}

enum ProgramField {
  ENGINEERING
  INFORMATION_TECHNOLOGY
  BUSINESS_MANAGEMENT
  ACCOUNTING_FINANCE
  MEDICINE
  HEALTHCARE
  NURSING
  PHARMACY
  BIO_TECHNOLOGY
  AGRICULTURE
  ENVIRONMENTAL_SCIENCE
  LAW
  PSYCHOLOGY
  SOCIAL_SCIENCE
  EDUCATION
  ARTS
  ARCHITECTURE
  MEDIA_COMMUNICATION
  JOURNALISM
  LOGISTICS
  TOURISM_HOSPITALITY
  MARITIME
  FASHION_DESIGN
  INTERIOR_DESIGN
  GRAPHIC_DESIGN
  MUSIC
  PERFORMING_ARTS
  SPORTS_SCIENCE
  POLITICAL_SCIENCE
  ECONOMICS
  MATHEMATICS
  PHYSICS
  CHEMISTRY
  DATA_SCIENCE
  ARTIFICIAL_INTELLIGENCE
  CYBER_SECURITY
  OTHER

  @@schema("public")
}

enum DeliveryMode {
  ONLINE
  ON_CAMPUS
  HYBRID
  BLENDED

  @@schema("public")
}

enum LecturerRole {
  LECTURER
  CO_LECTURER
  SUPERVISOR

  @@schema("public")
}

enum EmploymentStatus {
  STUDENT
  EMPLOYED
  SELF_EMPLOYED
  UNEMPLOYED

  @@schema("public")
}

enum EnrollmentStatus {
  PENDING
  APPROVED
  ACTIVE
  COMPLETED
  SUSPENDED
  WITHDRAWN

  @@schema("public")
}

enum CourseEnrollmentStatus {
  ACTIVE
  COMPLETED
  FAILED
  WITHDRAWN

  @@schema("public")
}

enum AssessmentType {
  ASSIGNMENT
  QUIZ
  EXAM
  PROJECT
  PRESENTATION

  @@schema("public")
}

enum SubmissionStatus {
  SUBMITTED
  GRADED
  RESUBMIT_REQUIRED

  @@schema("public")
}

enum ResourceType {
  EBOOK
  JOURNAL
  VIDEO_LECTURE
  RESEARCH_PAPER
  SIMULATION
  PAST_PAPER

  @@schema("public")
}

enum AccessLevel {
  PUBLIC
  ENROLLED
  PREMIUM

  @@schema("public")
}

enum CredentialType {
  CERTIFICATE
  DIPLOMA
  DEGREE
  MICROCREDENTIAL

  @@schema("public")
}

enum JobType {
  FULL_TIME
  PART_TIME
  INTERNSHIP
  CONTRACT
  OVERSEAS

  @@schema("public")
}

enum ApplicationStatus {
  APPLIED
  SHORTLISTED
  INTERVIEW
  OFFERED
  REJECTED
  WITHDRAWN

  @@schema("public")
}

enum PaymentType {
  TUITION
  SUBSCRIPTION
  CERTIFICATION
  LIBRARY
  APPLICATION_FEE

  @@schema("public")
}

enum PaymentMethod {
  STRIPE
  PAYHERE
  BANK_TRANSFER
  SCHOLARSHIP

  @@schema("public")
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED

  @@schema("public")
}

enum SubscriptionPlan {
  FREE
  STUDENT_LOCAL
  STUDENT_FOREIGN
  INSTITUTION
  CORPORATE

  @@schema("public")
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PAUSED

  @@schema("public")
}

enum NotificationType {
  ENROLLMENT
  PAYMENT
  ASSIGNMENT
  GRADE
  JOB
  SYSTEM
  ANNOUNCEMENT

  @@schema("public")
}

enum CourseResourceType {
  PDF
  VIDEO_UPLOAD
  VIDEO_LINK
  IMAGE
  PRESENTATION
  EXTERNAL_LINK

  @@schema("public")
}
